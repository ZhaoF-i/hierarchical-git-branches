{
  "name": "hierarchical-git-branches",
  "displayName": "Hierarchical Git Branches",
  "description": "Show Git branches as a slash-separated tree in the VS Code Source Control sidebar.",
  "version": "1.0.2",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZhaoF-i/hierarchical-git-branches.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "scripts": {
    "package": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && vsce package --out dist/hierarchical-git-branches.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:hierarchicalGitBranches.scmView",
    "onView:hierarchicalGitBranches.activityView",
    "onCommand:hierarchicalGitBranches.refresh",
    "onCommand:hierarchicalGitBranches.filterBranches",
    "onCommand:hierarchicalGitBranches.clearFilter",
    "onCommand:hierarchicalGitBranches.checkout",
    "onCommand:hierarchicalGitBranches.createBranchFromSelected",
    "onCommand:hierarchicalGitBranches.deleteBranchEverywhere",
    "onCommand:hierarchicalGitBranches.copyCheckoutCommand",
    "onCommand:hierarchicalGitBranches.toggleFavorite",
    "onCommand:hierarchicalGitBranches.pushCurrentBranch",
    "onCommand:hierarchicalGitBranches.updateSelectedBranch",
    "onCommand:hierarchicalGitBranches.renameBranch",
    "onCommand:hierarchicalGitBranches.fetch",
    "onCommand:hierarchicalGitBranches.copyBranchName"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hierarchicalGitBranches.container",
          "title": "Branch Tree",
          "icon": "resources/branch.svg"
        }
      ]
    },
    "views": {
      "hierarchicalGitBranches.container": [
        {
          "id": "hierarchicalGitBranches.activityView",
          "name": "Branches"
        }
      ],
      "scm": [
        {
          "id": "hierarchicalGitBranches.scmView",
          "name": "Branch Tree"
        }
      ]
    },
    "commands": [
      {
        "command": "hierarchicalGitBranches.refresh",
        "title": "Branch Tree: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "hierarchicalGitBranches.filterBranches",
        "title": "Branch Tree: Filter Branches",
        "icon": "$(filter)"
      },
      {
        "command": "hierarchicalGitBranches.clearFilter",
        "title": "Branch Tree: Clear Filter",
        "icon": "$(clear-all)"
      },
      {
        "command": "hierarchicalGitBranches.checkout",
        "title": "Branch Tree: Checkout"
      },
      {
        "command": "hierarchicalGitBranches.createBranchFromSelected",
        "title": "Branch Tree: Create Branch From Selected"
      },
      {
        "command": "hierarchicalGitBranches.deleteBranchEverywhere",
        "title": "Branch Tree: Delete Local and Remote Branch"
      },
      {
        "command": "hierarchicalGitBranches.copyCheckoutCommand",
        "title": "Branch Tree: Copy Checkout Command"
      },
      {
        "command": "hierarchicalGitBranches.toggleFavorite",
        "title": "Branch Tree: Toggle Pin"
      },
      {
        "command": "hierarchicalGitBranches.pushCurrentBranch",
        "title": "Branch Tree: Push Current Branch",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "hierarchicalGitBranches.updateSelectedBranch",
        "title": "Branch Tree: Pull or Fetch Selected Branch"
      },
      {
        "command": "hierarchicalGitBranches.renameBranch",
        "title": "Branch Tree: Rename Branch"
      },
      {
        "command": "hierarchicalGitBranches.fetch",
        "title": "Branch Tree: Fetch All",
        "icon": "$(cloud-download)"
      },
      {
        "command": "hierarchicalGitBranches.copyBranchName",
        "title": "Branch Tree: Copy Branch Name"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hierarchicalGitBranches.pushCurrentBranch",
          "when": "view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView",
          "group": "navigation@1"
        },
        {
          "command": "hierarchicalGitBranches.fetch",
          "when": "view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView",
          "group": "navigation@2"
        },
        {
          "command": "hierarchicalGitBranches.filterBranches",
          "when": "view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView",
          "group": "navigation@3"
        },
        {
          "command": "hierarchicalGitBranches.clearFilter",
          "when": "view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView",
          "group": "navigation@4"
        },
        {
          "command": "hierarchicalGitBranches.refresh",
          "when": "view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "hierarchicalGitBranches.checkout",
          "when": "(view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView) && viewItem == branch",
          "group": "inline@1"
        },
        {
          "command": "hierarchicalGitBranches.createBranchFromSelected",
          "when": "(view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView) && viewItem == branch",
          "group": "navigation@1"
        },
        {
          "command": "hierarchicalGitBranches.updateSelectedBranch",
          "when": "(view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView) && viewItem == branch",
          "group": "navigation@2"
        },
        {
          "command": "hierarchicalGitBranches.renameBranch",
          "when": "(view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView) && viewItem == branch",
          "group": "navigation@3"
        },
        {
          "command": "hierarchicalGitBranches.toggleFavorite",
          "when": "(view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView) && viewItem == branch",
          "group": "navigation@4"
        },
        {
          "command": "hierarchicalGitBranches.deleteBranchEverywhere",
          "when": "(view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView) && viewItem == branch",
          "group": "navigation@5"
        },
        {
          "command": "hierarchicalGitBranches.copyBranchName",
          "when": "(view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView) && viewItem == branch",
          "group": "navigation@6"
        },
        {
          "command": "hierarchicalGitBranches.copyCheckoutCommand",
          "when": "(view == hierarchicalGitBranches.scmView || view == hierarchicalGitBranches.activityView) && viewItem == branch",
          "group": "navigation@7"
        }
      ]
    },
    "configuration": {
      "title": "Hierarchical Git Branches",
      "properties": {
        "hierarchicalGitBranches.includeRemoteBranches": {
          "type": "boolean",
          "default": true,
          "description": "Show remote branches below a Remotes section."
        },
        "hierarchicalGitBranches.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh the branch tree when the active editor or workspace changes."
        },
        "hierarchicalGitBranches.showLastCommitTime": {
          "type": "boolean",
          "default": false,
          "description": "Show the last commit time next to each branch."
        }
      }
    }
  }
}
